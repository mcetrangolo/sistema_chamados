SECRET_KEY=troque-esta-chave-em-producao
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Use postgresql em produção ou sqlite para testes locais rápidos.
DB_ENGINE=postgresql

POSTGRES_DB=sistema_chamados
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_CONNECT_TIMEOUT=5

SQLITE_NAME=db.sqlite3

GOVERNANCA_DOCUMENT_ROOT=media/governanca_documentos

AD_SERVER=ldap://dc.seudominio.local
AD_USER=SEUDOMINIO\\usuario_consulta
AD_PASSWORD=senha
AD_BASE_DN=DC=seudominio,DC=local
AD_COMPUTERS_FILTER=(objectClass=computer)
AD_USERS_FILTER=(objectClass=user)

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.seudominio.local
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=usuario
EMAIL_HOST_PASSWORD=senha
DEFAULT_FROM_EMAIL=helpdesk@seudominio.local
